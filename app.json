{
  "expo": {
    "name": "ComfeeProject",
    "slug": "ComfeeProject",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "comfeeproject",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/logo.png",

    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#E6F4FE"
      },

      "predictiveBackGestureEnabled": false,
      "package": "com.comfee.ComfeeProject"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "6d3fd0c8-5801-4114-8f70-7cc128bcc28f"
      }
    }
  }
}
