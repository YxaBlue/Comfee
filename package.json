    "base64-arraybuffer": "^1.0.2",
    "date-fns": "^4.2.1",
    "expo": "~55.0.23",
    "expo-auth-session": "~55.0.16",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.34",
    "expo-file-system": "~55.0.20",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.9",
